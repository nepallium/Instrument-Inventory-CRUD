<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/style.css">
  <title><%= title %> </title>
</head>

<body>
  <h1>Products</h1>
  <main>
    <div class="products">
      <% products.forEach(product => { %>
      <%- include('product', product) %>
      <% }) %>
    </div>
  </main>
</body>

</html>