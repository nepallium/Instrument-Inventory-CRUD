<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
</head>

<body>
  <div class="product">
    <%- include("product", locals) %>
    <div>
      <a href="/products/update/<%= id %>"><button>Edit</button></a>
      <form action="/products/delete/<%= id %>" method="POST" style="display:inline;">
        <button type="submit" onclick="return confirm('Are you sure you want to delete instrument?');">Delete</button>
      </form>
    </div>
  </div>
</body>

</html>